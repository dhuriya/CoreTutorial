@model CoreLearn.Models.Product
@{
    ViewData["Title"]="Create Product";
}
<div class="container mt-4">
    <h2 class="mb04">Create Product</h2>
    <form asp-action="Create" method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control">
            <span asp-validation-for="Name" class="text-danger" ></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control">
            <span asp-validation-for="Description" class="text-danger" ></span>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control">
            <span asp-validation-for="Price" class="text-danger" ></span>
        </div>
        <div class="mb-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" type="number">
            <span asp-validation-for="Stock" class="text-danger" ></span>
        </div>
        <button type="submit" class="btn btn-success">Create</button>
        <a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>
    </form>
</div>